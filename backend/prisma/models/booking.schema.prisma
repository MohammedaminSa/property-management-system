model Booking {
  id String @id @default(uuid())

  checkIn  DateTime
  checkOut DateTime

  // NEW FIELDS
  cancelledCheckIn  DateTime? // stores the original check-in when cancelled/rejected
  cancelledCheckOut DateTime? // stores the original check-out when cancelled/rejected

  guests       Int
  manualBooked Boolean @default(false)

  // Optional relation: user may not exist for manual bookings
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId String?

  // Manual customer info for non-registered guests
  guestName  String?
  guestPhone String?
  guestEmail String?

  // The admin or staff who approved the booking
  status BookingStatus @default(PENDING)

  rejectionReason String? // optional reason when rejected
  brokerApprovedAt DateTime? // when broker pre-approved, waiting for owner

  approvedBy   User?   @relation("ApprovedBookings", fields: [approvedById], references: [id])
  approvedById String?

  // The room being booked
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId String

  // Optional: reference to the property (can be inferred from room)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String

  // Activities related to this booking (logs, events, etc.)
  activities Activity[]

  totalAmount Decimal @db.Decimal(10, 2)
  subTotal    Decimal @db.Decimal(10, 2)
  basePrice   Decimal @db.Decimal(10, 2)

  taxAmount Decimal @db.Decimal(10, 2)
  discount  Decimal @default(0.00) @db.Decimal(10, 2)
  currency  String  @default("ETB")

  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commission   Commission?
  commsionJson Json?

  additionalServices AdditionalService[]

  @@index([checkIn, checkOut])
  @@index([status])
  @@index([propertyId])
}

model Commission {
  id        String  @id @default(uuid())
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String  @unique

  platformPercent Float
  brokerPercent   Float?

  platformAmount Float
  brokerAmount   Float?

  paidToBroker   Boolean @default(false)
  paidToPlatform Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id        String  @id @default(uuid())
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String  @unique

  status         PaymentStatus @default(PENDING)
  transactionRef String? // reference from payment gateway
  transactionId  String?

  phoneNumber   String?
  amount        Float?        @default(0)
  pendingAmount Float?        @default(0)
  method        PaymentMethod

  chapaSubAccount   ChapaSubAccount? @relation(fields: [chapaSubAccountId], references: [id])
  chapaSubAccountId String?

  metadata Json? // Store extra info like user_id, notes, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PaymentMethod {
  ONLINE
  CASH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum BookingStatus {
  PENDING
  PENDING_OWNER_APPROVAL
  PENDING_OWNER_REJECTION
  APPROVED
  REJECTED
  CANCELLED
}
