model ChapaSubAccount {
    id String @id @default(cuid())

    chapaSubId    String  @unique // Chapa subaccount ID
    businessName  String?
    accountName   String
    bankCode      String
    accountNumber String

    splitType  String // "percentage" or "flat"
    splitValue Float

    owner   User   @relation(fields: [ownerId], references: [id])
    ownerId String @unique

    type     SubAccountType
    status   SubAccountStatus @default(ACTIVE)
    balance  Float            @default(0)
    payments Payment[]

    // ✅ Relation fields live here ONLY
    propertyId String   @unique
    property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum SubAccountStatus {
    ACTIVE
    INACTIVE
}

// Enum for SubAccount types
enum SubAccountType {
    BROKER
    OWNER
    PLATFORM
}
